{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "OnTime Moving (Flask + Chrome)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server.py",
            "console": "integratedTerminal",
            "env": { "FLASK_ENV": "development" },
            "serverReadyAction": {
                "action": "runCommand",
                "command": "workbench.action.tasks.runTask",
                "commandArgument": "Open in Chrome",
                "pattern": "Running on (http://localhost:\\d+)"
            }
        }
    ]
}
